# Padrino environment configuration
# Copy to .env and fill in real values. .env is git-ignored.

# === Primary LLM provider (required for real games) ===
# Cerebras hosts zai-glm-4.7 with a generous free tier; used as primary by default.
CEREBRAS_API_KEY=

# === Fallback LLM provider (recommended) ===
# DeepInfra hosts deepseek-ai/DeepSeek-V4-Flash as the fallback model.
# Also hosts google/gemma-4-26B-A4B-it for roster diversity.
DEEPINFRA_API_KEY=

# === Z.AI (zai.io) ===
# Hosts GLM-5.1 (new flagship) and GLM-4.7 (same weights as Cerebras's, used
# as a same-model multi-host fallback when Cerebras rate-limits or 5xxs).
# OpenAI-compatible at https://api.z.ai/api/paas/v4/.
ZAI_API_KEY=

# === Xiaomi token-plan (SGP) ===
# Hosts Mimo-v2.5 and Mimo-v2.5-pro on an OpenAI-compatible endpoint.
XIAOMI_API_KEY=
XIAOMI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

# === Engine defaults ===
PADRINO_DB_URL=sqlite+aiosqlite:///./padrino.db
PADRINO_LOG_LEVEL=INFO
PADRINO_LLM_TIMEOUT_SECONDS=45
PADRINO_TEMPERATURE=0.7
PADRINO_TOP_P=1.0

# === Model routing ===
# Primary model used when an agent_build does not pin a specific model.
PADRINO_PRIMARY_MODEL=cerebras/zai-glm-4.7
PADRINO_FALLBACK_MODEL=deepinfra/deepseek-ai/DeepSeek-V4-Flash

# === Server (only used if running the FastAPI app) ===
PADRINO_API_HOST=127.0.0.1
PADRINO_API_PORT=8000

# === docker-compose stack (US-064) ===
# Postgres password for the bundled `postgres` service (also reflected in
# PADRINO_DB_URL which docker-compose.yml builds for the api / scheduler /
# bootstrap services automatically).
POSTGRES_PASSWORD=padrino
# Override the image tag built by `docker compose build` (defaults to
# `padrino:dev`). Set this when pulling a published GHCR image instead.
PADRINO_IMAGE=padrino:dev
# Concurrency for the bundled scheduler container.
PADRINO_SCHEDULER_CONCURRENCY=4
